# Chave de API da Groq Cloud (obrigatória para habilitar a análise de IA).
# Gratuita em https://console.groq.com/keys — sem ela, o app funciona normalmente,
# mas a coluna "Motivo" fica sem os insights gerados por IA.
GROQ_API_KEY=

# Senha opcional para liberar o botão de análise IA na interface.
# Deixe em branco para não exigir senha.
AI_ACCESS_PASSWORD=

# Limite de chamadas à IA por sessão de usuário (protege sua quota/custo na Groq).
MAX_AI_CALLS_PER_SESSION=15
